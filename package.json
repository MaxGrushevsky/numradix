{
  "name": "numradix",
  "version": "1.0.0",
  "description": "Number base conversion toolkit — bases 2–36, BigInt precision, custom alphabets, formatting. Zero dependencies. TypeScript-first.",
  "keywords": [
    "base",
    "radix",
    "binary",
    "octal",
    "hexadecimal",
    "base conversion",
    "number system",
    "bigint",
    "base62",
    "base58",
    "encode",
    "decode"
  ],
  "author": "MaxGrushevsky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxGrushevsky/numradix.git"
  },
  "homepage": "https://github.com/MaxGrushevsky/numradix#readme",
  "bugs": {
    "url": "https://github.com/MaxGrushevsky/numradix/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
